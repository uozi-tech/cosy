{
  "devDependencies": {
    "vite": "^8.1.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-legend": "^2.0.0",
    "vue": "^3.5.39"
  },
  "scripts": {
    "docs:sync": "mkdir -p docs/public/debug-app && cp -r debug/app/css debug/app/js debug/app/fonts debug/app/assets docs/public/debug-app/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "npm run docs:sync && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.18.1",
      "esbuild": "^0.28.1",
      "dompurify": "^3.4.11",
      "js-yaml": "4.3.0",
      "linkify-it": "^5.0.2",
      "markdown-it": "^14.3.0",
      "mermaid": "^11.16.0",
      "undici": "^6.27.0",
      "vite@^7.0.0": "^7.3.6",
      "vitepress>vite": "^6.4.3"
    }
  }
}
